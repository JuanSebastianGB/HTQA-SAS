# HTQA-SAS Event Microservice - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# --- Docker Compose (servicio postgres; deben coincidir usuario/clave/DB con DATABASE_URL)
POSTGRES_USER=htqa
POSTGRES_PASSWORD=htqa_pass
POSTGRES_DB=htqa_events

# Puertos publicados en el host (solo Compose; el contenedor de la API escucha en 8000)
COMPOSE_APP_PORT=8000
COMPOSE_POSTGRES_PORT=5432
COMPOSE_REDIS_PORT=6379

# API Configuration
API_KEY=your-secure-api-key-here

# Database Configuration
# PostgreSQL (docker compose: host "postgres", credenciales como arriba):
DATABASE_URL=postgresql+asyncpg://htqa:htqa_pass@postgres:5432/htqa_events
# SQLite (local development only):
# DATABASE_URL=sqlite+aiosqlite:///./htqa_events.db

# Redis Configuration
REDIS_URL=redis://redis:6379/0
# Rate limit si Redis falla: true = permitir tráfico (fail-open); false = propagar error
RATE_LIMIT_FAIL_OPEN=true

# Application (referencia para arranque manual con uvicorn; Dockerfile/Compose usan 0.0.0.0:8000)
APP_HOST=0.0.0.0
APP_PORT=8000
# main.py usa nivel INFO por defecto; no lee LOG_LEVEL del entorno aún
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Idempotency
IDEMPOTENCY_TTL_SECONDS=300

# Critical event notifications (mock email logs recipient)
NOTIFICATION_RECIPIENT_EMAIL=ops@htqa.local
