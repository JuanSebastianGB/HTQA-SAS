# Plantilla para producción: copiar a un fichero fuera del repo (p. ej. /etc/htqa-events.env)
# y referenciarlo con docker run --env-file.
# No commitear secretos.

API_KEY=

# PostgreSQL gestionado (RDS, Cloud SQL, instancia dedicada): host real, no nombre de servicio compose.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db.example.com:5432/htqa_events

# Redis gestionado (ElastiCache, Memorystore, instancia dedicada).
REDIS_URL=redis://:PASSWORD@redis.example.com:6379/0

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
WEB_CONCURRENCY=2
# Restringir a IPs/CIDRs del proxy cuando sea posible.
FORWARDED_ALLOW_IPS=*

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=300

NOTIFICATION_RECIPIENT_EMAIL=ops@example.com
